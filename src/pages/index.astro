---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import ArticleCard from "../components/ArticleCard.astro";

const globalArticles = (await getCollection("global"))
    .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
    .slice(0, 3);

const palestineArticles = (await getCollection("palestine"))
    .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
    .slice(0, 3);
---

<Layout>
    <Header />
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <section class="mb-16">
            <div class="flex justify-between items-end mb-8">
                <h2
                    class="text-3xl font-bold text-slate-900 border-r-4 border-red-600 pr-4"
                >
                    عالمی خبریں
                </h2>
                <a
                    href="/global"
                    class="text-red-600 hover:text-red-700 font-medium"
                    >مزید دیکھیں &larr;</a
                >
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {
                    globalArticles.map((article) => (
                        <ArticleCard
                            title={article.data.title}
                            author={article.data.author}
                            publishDate={article.data.publishDate}
                            heroImage={article.data.heroImage}
                            href={`/global/${article.id}`}
                        />
                    ))
                }
            </div>
        </section>

        <section>
            <div class="flex justify-between items-end mb-8">
                <h2
                    class="text-3xl font-bold text-slate-900 border-r-4 border-red-600 pr-4"
                >
                    فلسطین
                </h2>
                <a
                    href="/palestine"
                    class="text-red-600 hover:text-red-700 font-medium"
                    >مزید دیکھیں &larr;</a
                >
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {
                    palestineArticles.map((article) => (
                        <ArticleCard
                            title={article.data.title}
                            author={article.data.author}
                            publishDate={article.data.publishDate}
                            heroImage={article.data.heroImage}
                            href={`/palestine/${article.id}`}
                        />
                    ))
                }
            </div>
        </section>
    </main>
</Layout>
