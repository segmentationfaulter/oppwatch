---
const navItems = [
	{ label: 'گھر', href: '/' },
	{ label: 'عالمی خبریں', href: '/global' },
	{ label: 'فلسطین', href: '/palestine' },
];
---

<header class="bg-white border-b border-slate-200 sticky top-0 z-50">
	<nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="flex justify-between h-16 items-center">
			<div class="flex-shrink-0">
				<a href="/" class="text-2xl font-bold text-red-600">OppWatch</a>
			</div>
			<div class="hidden sm:ml-6 sm:flex sm:space-x-8 sm:space-x-reverse">
				{navItems.map(item => (
					<a
						href={item.href}
						class="inline-flex items-center px-1 pt-1 text-sm font-medium text-slate-900 hover:text-red-600 transition-colors"
					>
						{item.label}
					</a>
				))}
			</div>
		</div>
	</nav>
</header>
